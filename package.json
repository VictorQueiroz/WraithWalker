{
  "name": "wraithwalker",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "packageManager": "npm@11.11.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "npm run test:release && turbo run test",
    "test:release": "node --test scripts/release.test.mjs",
    "typecheck": "turbo run typecheck",
    "generate:icons": "turbo run generate:icons --filter=@wraithwalker/extension",
    "release:prepare": "node scripts/release-prepare.mjs",
    "release:check": "node scripts/release-check.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^6.0.2"
  }
}
