{
  "name": "wraithwalker",
  "version": "2.0.1",
  "private": true,
  "license": "MIT",
  "packageManager": "npm@11.11.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "npm run coverage",
    "test:versioning": "node --test scripts/versioning.test.mjs scripts/check-changeset.test.mjs scripts/extension-release.test.mjs",
    "test:workspaces": "turbo run test",
    "coverage": "npm run test:versioning && npm run test:workspaces && npm run coverage:report",
    "coverage:report": "node scripts/coverage-report.mjs",
    "typecheck": "turbo run typecheck",
    "generate:icons": "turbo run generate:icons --filter=@wraithwalker/extension",
    "changeset": "changeset",
    "sync:extension-manifest-version": "node scripts/sync-extension-manifest-version.mjs",
    "version:packages": "changeset version && npm run sync:extension-manifest-version",
    "release:prepare": "npm run version:packages",
    "release:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "turbo": "^2.5.4",
    "typescript": "^6.0.2"
  }
}
