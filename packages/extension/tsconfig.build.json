{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["chrome"],
    "rootDir": "src",
    "outDir": ".ts-emit",
    "declaration": false,
    "sourceMap": false,
    "removeComments": false,
    "newLine": "lf",
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": [
    "src/background.ts",
    "src/offscreen.ts",
    "src/lib/**/*.ts",
    "src/lib/**/*.tsx",
    "src/ui/**/*.ts",
    "src/ui/**/*.tsx",
    "src/**/*.d.ts",
    "types/**/*.d.ts"
  ]
}
