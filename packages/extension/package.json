{
  "name": "@wraithwalker/extension",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node --import tsx scripts/build.ts",
    "test": "npm run build && vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.tests.json",
    "generate:icons": "node --import tsx scripts/generate-icons.ts",
    "check:background": "npm run build && node --check dist/background.js",
    "check:popup": "npm run build && node --check dist/popup.js",
    "check:options": "npm run build && node --check dist/options.js",
    "check:offscreen": "npm run build && node --check dist/offscreen.js"
  },
  "dependencies": {
    "@trpc/client": "^11.7.1",
    "@wraithwalker/core": "2.1.0",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.9",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
