{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "checkJs": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["DOM", "ES2022"],
    "types": ["node", "vitest/globals", "chrome"]
  },
  "include": [
    "tests/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "coverage",
    "dist",
    "node_modules"
  ]
}
