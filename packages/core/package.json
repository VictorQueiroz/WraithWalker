{
  "name": "@wraithwalker/core",
  "version": "2.2.1",
  "description": "Shared Node-side domain logic for WraithWalker fixture roots, scenarios, and context generation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VictorQueiroz/WraithWalker.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/VictorQueiroz/WraithWalker/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/VictorQueiroz/WraithWalker/issues"
  },
  "keywords": [
    "wraithwalker",
    "fixtures",
    "core",
    "scenarios",
    "context"
  ],
  "private": false,
  "type": "module",
  "files": [
    "out",
    "README.md"
  ],
  "exports": {
    "./fixture-layout": "./out/fixture-layout.mjs",
    "./fixture-repository": "./out/fixture-repository.mjs",
    "./site-config": "./out/site-config.mjs",
    "./project-config": "./out/project-config.mjs",
    "./scenario-traces": "./out/scenario-traces.mjs",
    "./root-runtime": "./out/root-runtime.mjs",
    "./root": "./out/root.mjs",
    "./root-fs": "./out/root-fs.mjs",
    "./fixtures": "./out/fixtures.mjs",
    "./scenarios": "./out/scenarios.mjs",
    "./context": "./out/context.mjs",
    "./har-import": "./out/har-import.mjs",
    "./overrides-sync": "./out/overrides-sync.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ignore": "^7.0.5",
    "prettier": "^3.6.2"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.tests.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
