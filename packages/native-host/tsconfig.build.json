{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {},
    "rootDir": "src",
    "outDir": "out",
    "declaration": true,
    "sourceMap": false,
    "removeComments": false,
    "newLine": "lf",
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["src/**/*.mts"]
}
