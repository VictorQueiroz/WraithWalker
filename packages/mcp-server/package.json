{
  "name": "@wraithwalker/mcp-server",
  "version": "0.4.0",
  "description": "MCP server for exposing WraithWalker fixture directories to AI agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VictorQueiroz/WraithWalker.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/VictorQueiroz/WraithWalker/tree/main/packages/mcp-server#readme",
  "bugs": {
    "url": "https://github.com/VictorQueiroz/WraithWalker/issues"
  },
  "keywords": [
    "wraithwalker",
    "mcp",
    "model-context-protocol",
    "fixtures",
    "ai"
  ],
  "private": false,
  "type": "module",
  "files": [
    "out",
    "README.md"
  ],
  "exports": {
    "./fixture-reader": "./out/fixture-reader.mjs",
    "./fixture-diff": "./out/fixture-diff.mjs",
    "./server": "./out/server.mjs"
  },
  "bin": {
    "wraithwalker-mcp": "out/bin.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x out/bin.mjs",
    "prepack": "npm run build",
    "test": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.tests.json"
  },
  "dependencies": {
    "@wraithwalker/core": "0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
