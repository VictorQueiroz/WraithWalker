{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": "src/native-host",
    "outDir": ".ts-emit/native-host",
    "declaration": false,
    "sourceMap": false,
    "removeComments": false,
    "newLine": "lf",
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": [
    "src/native-host/**/*.mts"
  ]
}
